<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FitApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FitApp.Views"
    FlyoutBehavior="Disabled"
    Title="FitApp">

    <!-- Нижние вкладки (все платформы) -->
    <TabBar>
        <Tab Title="Главная">
            <ShellContent Route="MainPage"
                          ContentTemplate="{DataTemplate views:MainPage}"/>
        </Tab>
        <Tab Title="Тренировки">
            <ShellContent Route="WorkoutListPage"
                          ContentTemplate="{DataTemplate views:WorkoutListPage}"/>
        </Tab>
        <Tab Title="Шаблоны">
            <ShellContent Route="TemplatesPage"
                          ContentTemplate="{DataTemplate views:TemplatesPage}"/>
        </Tab>
        <Tab Title="Прогресс">
            <ShellContent Route="ProgressPage"
                          ContentTemplate="{DataTemplate views:ProgressPage}"/>
        </Tab>
        <Tab Title="Упражнения">
            <ShellContent Route="ExercisePage"
                          ContentTemplate="{DataTemplate views:ExercisePage}"/>
        </Tab>
        <Tab Title="Настройки">
            <ShellContent Route="SettingsPage"
                          ContentTemplate="{DataTemplate views:SettingsPage}"/>
        </Tab>
    </TabBar>

    <!-- Аккаунт — не вкладка, попадаем через "Настройки → Аккаунт" -->
    <ShellContent Route="AccountPage"
                  ContentTemplate="{DataTemplate views:AccountPage}"
                  FlyoutItemIsVisible="False"/>

</Shell>
