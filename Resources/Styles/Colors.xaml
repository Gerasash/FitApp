<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============ БРЕНД ============ -->
    <Color x:Key="Primary">#FF9B00</Color>
    <Color x:Key="PrimaryDark">#FF6F00</Color>
    <Color x:Key="PrimaryLight">#FFB74D</Color>
    <Color x:Key="PrimaryDarkText">#E1E1E1</Color>
    <Color x:Key="Secondary">#FFB74D</Color>
    <Color x:Key="SecondaryDarkText">#FF8C00</Color>
    <Color x:Key="Tertiary">#FF5722</Color>

    <!-- Legacy (для обратной совместимости) -->
    <Color x:Key="Magenta">#FF9B00</Color>
    <Color x:Key="MidnightBlue">#111827</Color>
    <Color x:Key="OffBlack">#0B0E14</Color>

    <!-- ============ ПАЛИТРА (raw) ============ -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <Color x:Key="Gray50">#FAFBFC</Color>
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray700">#374151</Color>
    <Color x:Key="Gray800">#1F2937</Color>
    <Color x:Key="Gray900">#111827</Color>
    <Color x:Key="Gray950">#0B0E14</Color>

    <!-- ============ ТОКЕНЫ: пары Light/Dark ============ -->
    <!-- Используются через {AppThemeBinding Light={StaticResource XLight}, Dark={StaticResource XDark}} -->

    <!-- Фоны -->
    <Color x:Key="BgPrimaryLight">#FAFBFC</Color>
    <Color x:Key="BgPrimaryDark">#0B0E14</Color>
    <Color x:Key="BgSurfaceLight">#FFFFFF</Color>
    <Color x:Key="BgSurfaceDark">#161A22</Color>
    <Color x:Key="BgElevatedLight">#FFFFFF</Color>
    <Color x:Key="BgElevatedDark">#1F2430</Color>
    <Color x:Key="BgMutedLight">#F3F4F6</Color>
    <Color x:Key="BgMutedDark">#1A1F28</Color>

    <!-- Текст -->
    <Color x:Key="TextPrimaryLight">#111827</Color>
    <Color x:Key="TextPrimaryDark">#E8E9EB</Color>
    <Color x:Key="TextSecondaryLight">#6B7280</Color>
    <Color x:Key="TextSecondaryDark">#9CA3AF</Color>
    <Color x:Key="TextMutedLight">#9CA3AF</Color>
    <Color x:Key="TextMutedDark">#6B7280</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <!-- Границы -->
    <Color x:Key="BorderSubtleLight">#E5E7EB</Color>
    <Color x:Key="BorderSubtleDark">#2A3140</Color>
    <Color x:Key="BorderStrongLight">#D1D5DB</Color>
    <Color x:Key="BorderStrongDark">#3A4356</Color>

    <!-- Семафор -->
    <Color x:Key="SuccessLight">#2E7D32</Color>
    <Color x:Key="SuccessDark">#66BB6A</Color>
    <Color x:Key="SuccessBgLight">#E8F5E9</Color>
    <Color x:Key="SuccessBgDark">#1B3A1F</Color>

    <Color x:Key="WarningLight">#F57C00</Color>
    <Color x:Key="WarningDark">#FFA726</Color>
    <Color x:Key="WarningBgLight">#FFF3E0</Color>
    <Color x:Key="WarningBgDark">#3A2A18</Color>

    <Color x:Key="DangerLight">#C62828</Color>
    <Color x:Key="DangerDark">#EF5350</Color>
    <Color x:Key="DangerBgLight">#FFEBEE</Color>
    <Color x:Key="DangerBgDark">#3A1E1E</Color>

    <Color x:Key="InfoLight">#1976D2</Color>
    <Color x:Key="InfoDark">#42A5F5</Color>
    <Color x:Key="InfoBgLight">#E3F2FD</Color>
    <Color x:Key="InfoBgDark">#1A2A3A</Color>

    <!-- ============ КИСТИ ============ -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
