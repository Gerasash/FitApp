        <mxCell id="a3" value="&lt;font style=&quot;font-size: 13px;&quot;&gt;Инженерия признаков&lt;br&gt;29 признаков · 118 350 пар обучения&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Times New Roman;fontSize=11;verticalAlign=middle;" parent="1" vertex="1">
