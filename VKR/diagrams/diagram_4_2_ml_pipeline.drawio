        <mxCell id="a2" value="&lt;font style=&quot;font-size: 13px;&quot;&gt;Синтетический датасет&lt;br&gt;500 атлетов · 763 322 подхода&lt;br&gt;(CSV ~80 МБ)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Times New Roman;fontSize=11;verticalAlign=middle;" parent="1" vertex="1">
