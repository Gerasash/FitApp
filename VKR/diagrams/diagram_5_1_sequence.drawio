        <!-- ══════════════════════════════════════════ -->
        <!-- ШАГ 1: Клиент — фиксация курсора и формирование push-батча -->
        <!-- ══════════════════════════════════════════ -->

        <mxCell id="step1_box"
          value="1. clientNowAtStart := DateTime.UtcNow&lt;br&gt;    pushBatch = записи WHERE UpdatedAt ≥ LastSyncUtc"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;
                 strokeColor=#d6b656;fontSize=11;fontFamily=Times New Roman;
                 align=left;spacingLeft=8;spacingRight=8;"
          vertex="1" parent="1">
          <mxGeometry x="170" y="105" width="340" height="50" as="geometry" />
        </mxCell>

        <!-- ШАГ 2: POST /sync -->
        <mxCell id="msg_post"
          value=""
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;
                 strokeWidth=1.5;strokeColor=#333333;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="157" y="225" as="sourcePoint" />
            <mxPoint x="513" y="225" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_post"
          value="2.  POST /sync  { pushBatch, lastSyncUtc }  |  Authorization: Bearer &lt;JWT&gt;"
          style="text;html=1;fontSize=11;fontFamily=Times New Roman;fontStyle=1;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="157" y="205" width="356" height="18" as="geometry" />
        </mxCell>

        <!-- ШАГ 3: UPSERT → DB -->
        <mxCell id="msg_upsert"
          value=""
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;
                 strokeWidth=1.5;strokeColor=#333333;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="527" y="270" as="sourcePoint" />
            <mxPoint x="883" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_upsert"
          value="3.  BEGIN TRANSACTION;  UPSERT push-батча (LWW: WHERE excluded.UpdatedAt &gt; existing)"
          style="text;html=1;fontSize=11;fontFamily=Times New Roman;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="527" y="250" width="356" height="18" as="geometry" />
        </mxCell>

        <!-- ШАГ 4: COMMIT → Server -->
        <mxCell id="msg_commit"
          value=""
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=0;
                 strokeWidth=1.5;strokeColor=#333333;dashed=1;dashPattern=6 3;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="883" y="305" as="sourcePoint" />
            <mxPoint x="527" y="305" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_commit"
          value="4.  COMMIT;  OK"
          style="text;html=1;fontSize=11;fontFamily=Times New Roman;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="527" y="308" width="356" height="18" as="geometry" />
        </mxCell>

        <!-- ШАГ 5: SELECT pull → DB -->
        <mxCell id="msg_select"
          value=""
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;
                 strokeWidth=1.5;strokeColor=#333333;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="527" y="350" as="sourcePoint" />
            <mxPoint x="883" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_select"
          value="5.  SELECT * WHERE UpdatedAt &gt; lastSyncUtc  AND user_id = ?"
          style="text;html=1;fontSize=11;fontFamily=Times New Roman;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="527" y="330" width="356" height="18" as="geometry" />
        </mxCell>

        <!-- ШАГ 6: pull rows → Server -->
        <mxCell id="msg_rows"
          value=""
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=0;
                 strokeWidth=1.5;strokeColor=#333333;dashed=1;dashPattern=6 3;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="883" y="390" as="sourcePoint" />
            <mxPoint x="527" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_rows"
          value="6.  строки pull-батча + ServerTimeUtc"
          style="text;html=1;fontSize=11;fontFamily=Times New Roman;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="527" y="393" width="356" height="18" as="geometry" />
        </mxCell>

        <!-- ШАГ 7: HTTP 200 → Client -->
        <mxCell id="msg_response"
          value=""
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=0;
