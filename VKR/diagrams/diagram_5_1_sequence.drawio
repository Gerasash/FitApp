          <mxGeometry x="70" y="658" width="200" height="16" as="geometry" />
        </mxCell>
        <mxCell id="leg_lww" value="LWW = Last-Write-Wins по полю UpdatedAt"
          style="text;html=1;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="70" y="676" width="320" height="16" as="geometry" />
        </mxCell>

        <!-- Caption -->
        <mxCell id="caption"
          value="Рисунок 5.1 — Диаграмма последовательности одного цикла синхронизации"
