        <!-- ════════ ШАГ 3: UPSERT ════════ -->
        <mxCell id="lbl_upsert"
          value="&lt;b&gt;3.&lt;/b&gt; BEGIN; UPSERT push-батча&#10;LWW: WHERE excluded.UpdatedAt &amp;gt; existing.UpdatedAt"
