          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="75" as="sourcePoint" />
            <mxPoint x="840" y="720" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ══════════════════════════════════════════ -->
        <!-- ACTIVATION BOXES (прямоугольники активации) -->
        <!-- ══════════════════════════════════════════ -->
        <mxCell id="act_client1" value=""
          style="fillColor=#dae8fc;strokeColor=#6c8ebf;"
          vertex="1" parent="1">
          <mxGeometry x="143" y="95" width="14" height="440" as="geometry" />
        </mxCell>
        <mxCell id="act_server1" value=""
          style="fillColor=#e1d5e7;strokeColor=#9673a6;"
          vertex="1" parent="1">
          <mxGeometry x="483" y="200" width="14" height="280" as="geometry" />
        </mxCell>
        <mxCell id="act_db1" value=""
          style="fillColor=#f5f5f5;strokeColor=#666;"
          vertex="1" parent="1">
          <mxGeometry x="833" y="235" width="14" height="175" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════ -->
        <!-- ШАГИ СИНХРОНИЗАЦИИ -->
        <!-- ══════════════════════════════════════════ -->

        <!-- Шаг 1: Клиент фиксирует clientNowAtStart и формирует push-батч -->
        <mxCell id="note_step1"
          value="1. clientNowAtStart := DateTime.UtcNow;&lt;br/&gt;    pushBatch = local records WHERE UpdatedAt ≥ LastSyncUtc"
          style="shape=callout;whiteSpace=wrap;html=1;fillColor=#fff2cc;
                 strokeColor=#d6b656;fontSize=9;align=left;spacingLeft=4;
                 perimeter=calloutPerimeter;size=10;position2=0;
                 direction=west;"
          vertex="1" parent="1">
          <mxGeometry x="170" y="100" width="310" height="50" as="geometry" />
        </mxCell>

        <!-- Шаг 2: POST /sync → Server -->
        <mxCell id="msg_post"
          value="POST /sync  { pushBatch, lastSyncUtc }&lt;br/&gt;Authorization: Bearer &lt;JWT&gt;"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;
                 fontSize=9;fontStyle=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;"
          edge="1" source="act_client1" target="act_server1" parent="1">
          <mxGeometry y="-50" relative="1" as="geometry">
            <mxPoint as="offset" x="10" y="-30" />
            <Array as="points">
              <mxPoint x="157" y="210" />
              <mxPoint x="483" y="210" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_post"
          value="2. POST /sync"
          style="text;html=1;fontSize=9;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="230" y="192" width="100" height="16" as="geometry" />
        </mxCell>

        <!-- Шаг 3: Server → DB (BEGIN TRANSACTION; UPSERT push-батча) -->
        <mxCell id="msg_upsert"
          value="BEGIN TRANSACTION;&lt;br/&gt;UPSERT each record (LWW: UpdatedAt)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;
                 fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;"
          edge="1" source="act_server1" target="act_db1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="497" y="248" />
              <mxPoint x="833" y="248" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_upsert"
          value="3. UPSERT (ON CONFLICT ... WHERE excluded.UpdatedAt &gt; existing)"
          style="text;html=1;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="510" y="230" width="310" height="16" as="geometry" />
        </mxCell>

        <!-- Шаг 4: DB → Server (OK) -->
        <mxCell id="msg_db_ok"
          value="COMMIT; OK"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=0;
                 fontSize=9;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;"
          edge="1" source="act_db1" target="act_server1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="833" y="278" />
              <mxPoint x="497" y="278" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_db_ok"
          value="4. COMMIT"
          style="text;html=1;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="660" y="260" width="70" height="16" as="geometry" />
        </mxCell>

        <!-- Шаг 5: Server → DB (SELECT изменения > lastSyncUtc) -->
        <mxCell id="msg_select"
          value="SELECT ... WHERE UpdatedAt &gt; lastSyncUtc"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;
                 fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;"
          edge="1" source="act_server1" target="act_db1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="497" y="318" />
              <mxPoint x="833" y="318" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_select"
          value="5. SELECT pull-данных"
          style="text;html=1;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="555" y="300" width="160" height="16" as="geometry" />
        </mxCell>

        <!-- Шаг 6: DB → Server (pullBatch + ServerTimeUtc) -->
        <mxCell id="msg_pull_rows"
          value="pullBatch rows"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=0;
                 fontSize=9;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;"
          edge="1" source="act_db1" target="act_server1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="833" y="358" />
              <mxPoint x="497" y="358" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_pull_rows"
          value="6. строки pull-батча"
          style="text;html=1;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="340" width="140" height="16" as="geometry" />
        </mxCell>

        <!-- Шаг 7: Server → Client (ответ: pullBatch + serverTimeUtc) -->
        <mxCell id="msg_response"
          value="HTTP 200: { pullBatch, serverTimeUtc }"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=0;
                 fontSize=9;fontStyle=1;dashed=0;exitX=0;exitY=0.5;entryX=1;entryY=0.5;"
          edge="1" source="act_server1" target="act_client1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="483" y="415" />
              <mxPoint x="157" y="415" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_response"
          value="7. HTTP 200 (pullBatch)"
          style="text;html=1;fontSize=9;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="220" y="397" width="180" height="16" as="geometry" />
        </mxCell>

        <!-- Шаг 8: Клиент применяет pull-батч и сохраняет курсор -->
        <mxCell id="note_step8"
          value="8. UPSERT pullBatch по SyncId в SQLite;&lt;br/&gt;    LastSyncUtc := clientNowAtStart"
          style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;
                 strokeColor=#82b366;fontSize=9;align=left;spacingLeft=4;
                 perimeter=calloutPerimeter;size=10;position2=0;
                 direction=west;"
          vertex="1" parent="1">
          <mxGeometry x="170" y="445" width="300" height="50" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════ -->
