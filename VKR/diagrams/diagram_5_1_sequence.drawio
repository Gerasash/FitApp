          <mxGeometry x="210" y="140" width="320" height="70" as="geometry" />
        </mxCell>

        <!-- ════════ ШАГ 2: POST /sync ════════ -->
        <mxCell id="lbl_post"
          value="&lt;b&gt;2.&lt;/b&gt; POST /sync { pushBatch, lastSyncUtc }&#10;Authorization: Bearer &amp;lt;JWT&amp;gt;"
          style="text;html=1;fontSize=11;fontFamily=Times New Roman;align=center;whiteSpace=wrap;"
          vertex="1" parent="1">
          <mxGeometry x="195" y="240" width="340" height="34" as="geometry" />
