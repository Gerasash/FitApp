            <mxPoint x="157" y="445" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_response"
          value="7.  HTTP 200  { pullBatch, serverTimeUtc }"
          style="text;html=1;fontSize=11;fontFamily=Times New Roman;fontStyle=1;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="157" y="425" width="356" height="18" as="geometry" />
        </mxCell>

        <!-- ШАГ 8: Клиент применяет pull-батч -->
        <mxCell id="step8_box"
          value="8. UPSERT pullBatch по SyncId в локальный SQLite&lt;br&gt;    LastSyncUtc := clientNowAtStart"
