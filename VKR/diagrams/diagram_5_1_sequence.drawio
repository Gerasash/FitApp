        <!-- ════════ ШАГ 1: локальная подготовка ════════ -->
        <mxCell id="step1_box"
          value="&lt;b&gt;1.&lt;/b&gt; clientNowAtStart := DateTime.UtcNow&#10;&#10;pushBatch ← записи WHERE UpdatedAt ≥ LastSyncUtc"
