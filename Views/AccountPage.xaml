<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FitApp.ViewModels"
             x:Class="FitApp.Views.AccountPage"
             x:DataType="vm:AccountViewModel"
             Title="Аккаунт">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="← Назад" Order="Primary" Priority="0" Clicked="OnBackClicked"/>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- ===== Не залогинен: форма входа/регистрации ===== -->
            <Border Style="{StaticResource Card}" IsVisible="{Binding IsLoggedOut}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Вход или регистрация" FontSize="18" FontAttributes="Bold"/>
                    <Label Text="Войдите, чтобы синхронизировать тренировки с облаком и видеть их на других устройствах."
                           Style="{StaticResource Caption}"/>

                    <Entry Placeholder="Email"
                           Text="{Binding Email}"
                           Keyboard="Email"/>

                    <Entry Placeholder="Пароль"
                           Text="{Binding Password}"
                           IsPassword="True"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="Войти"
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding IsNotBusy}"/>
                        <Button Grid.Column="1"
                                Text="Зарегистрироваться"
                                Style="{StaticResource SecondaryAction}"
                                Command="{Binding RegisterCommand}"
                                IsEnabled="{Binding IsNotBusy}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ===== Залогинен: синхронизация ===== -->
            <Border Style="{StaticResource Card}" IsVisible="{Binding IsLoggedIn}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Вы вошли как:" Style="{StaticResource Caption}"/>
                    <Label Text="{Binding Email}" FontSize="16" FontAttributes="Bold"/>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource BorderSubtleLight}, Dark={StaticResource BorderSubtleDark}}"/>

                    <Label Text="{Binding LastSyncText}" Style="{StaticResource Caption}"/>

                    <Button Text="🔄 Синхронизировать"
                            Command="{Binding SyncCommand}"
                            IsEnabled="{Binding IsNotBusy}"/>

                    <Button Text="Выйти"
                            Style="{StaticResource SecondaryAction}"
                            Command="{Binding LogoutCommand}"
                            IsEnabled="{Binding IsNotBusy}"/>
                </VerticalStackLayout>
            </Border>

            <!-- ===== Статус и индикатор занятости ===== -->
            <Border Style="{StaticResource Card}" IsVisible="{Binding HasStatus}">
                <HorizontalStackLayout Spacing="10">
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       VerticalOptions="Center"/>
                    <Label Text="{Binding StatusText}" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
