<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FitApp.ViewModels"
             x:Class="FitApp.Views.MainPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="{AppThemeBinding Light=#F7F8FA, Dark=#0F0F11}"
             Title="Главная">

    <!--
        Этап 4: главный экран превращён в чистый дашборд.

        До: четыре цветные плитки навигации (Тренировки, Прогресс, Группы
        мышц, Упражнения) дублировали Shell TabBar внизу, а большой hero
        с кнопкой «Начать тренировку» соревновался с тем же CTA внутри
        карточки планировщика.

        После:
        - Hero показывается ТОЛЬКО на пустой БД (первая установка) — это
          единственный осмысленный момент его существования.
        - Когда данные есть — пользователь видит подряд: план →
          сводки (последняя тренировка / активность) → мини-график 1ПМ.
        - Навигация по разделам уехала в Shell TabBar, сетка плиток
          удалена. Это уменьшает дубль и оставляет на главной только
          уникальный для неё контент.
        - Один layout вместо двух (телефон/ПК): на широком экране весь
          стек центрируется через MaximumWidthRequest.
    -->

    <ScrollView>
        <VerticalStackLayout Spacing="12"
                             Padding="20,20,20,32"
                             MaximumWidthRequest="720"
                             HorizontalOptions="Center">

            <!-- ===== Hero: только при пустой БД ===== -->
            <VerticalStackLayout Spacing="12"
                                 Padding="0,20,0,8"
                                 IsVisible="{Binding IsEmpty}">
                <Label Text="🏋️ FitApp"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Text="Ваш тренировочный дневник"
                       FontSize="15"
                       TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                       HorizontalOptions="Center"/>
                <Label Text="Создайте первую тренировку — приложение начнёт собирать вашу историю и подскажет рабочий вес на следующую."
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#888, Dark=#999}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,4,0,16"/>
                <Button Text="➕  Начать тренировку"
                        FontSize="17"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="14"
                        HeightRequest="56"
                        Command="{Binding StartWorkoutCommand}"/>
            </VerticalStackLayout>

            <!-- ===== Карточка планировщика ===== -->
            <Border StrokeShape="RoundRectangle 18"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource Primary}"
                    IsVisible="{Binding HasPlan}">
                <Grid Padding="20"
                      ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="6">

                    <Label Grid.Row="0" Grid.ColumnSpan="2"
                           Text="🎯  СЛЕДУЮЩАЯ ТРЕНИРОВКА"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="White"
                           Opacity="0.85"
                           CharacterSpacing="1"/>

                    <Label Grid.Row="1" Grid.ColumnSpan="2"
                           Text="{Binding PlanExerciseName}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           LineBreakMode="TailTruncation"
                           MaxLines="1"/>

                    <HorizontalStackLayout Grid.Row="2" Grid.Column="0"
                                           Spacing="14"
                                           Margin="0,4,0,0">
                        <Label Text="{Binding PlanWeightText}"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"/>
                        <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                            <Label Text="{Binding PlanSetsRepsText}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                            <Label Text="{Binding PlanRpeText}"
                                   FontSize="12"
                                   TextColor="White"
                                   Opacity="0.85"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <Button Grid.Row="3" Grid.ColumnSpan="2"
                            Text="▶  Начать тренировку"
                            FontSize="15"
                            FontAttributes="Bold"
                            BackgroundColor="White"
                            TextColor="{StaticResource Primary}"
                            CornerRadius="12"
                            HeightRequest="48"
                            Margin="0,10,0,0"
                            Command="{Binding StartWorkoutCommand}"/>
                </Grid>
            </Border>

            <!-- Подсказка, когда история есть, но плана пока нет -->
            <Border Padding="14"
                    StrokeShape="RoundRectangle 14"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2A2A2A}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}"
                    IsVisible="{Binding HasPlanHint}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="🎯  ПЛАНИРОВЩИК"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#888, Dark=#AAA}"
                           CharacterSpacing="1"/>
                    <Label Text="Накопите ещё пару тренировок одного упражнения — и планировщик начнёт советовать рабочий вес."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#444, Dark=#CCC}"
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Border>

            <!-- ===== Сводные карточки ===== -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  IsVisible="{Binding HasLastWorkout}">

                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#2A2A2A}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}"
                        Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenLastWorkoutCommand}"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="ПОСЛЕДНЯЯ ТРЕНИРОВКА"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#888, Dark=#AAA}"
                               CharacterSpacing="1"/>
                        <Label Text="{Binding LastWorkoutName}"
                               FontSize="16"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                        <Label Text="{Binding LastWorkoutWhen}"
                               FontSize="13"
                               TextColor="{StaticResource Primary}"/>
                        <Label Text="{Binding LastWorkoutMeta}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#666, Dark=#999}"
                               LineBreakMode="TailTruncation"
                               MaxLines="2"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#2A2A2A}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}"
                        Padding="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="АКТИВНОСТЬ"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#888, Dark=#AAA}"
                               CharacterSpacing="1"/>
                        <Label Text="{Binding WeekCountText}"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"/>
                        <Label Text="{Binding WeekCountCaption}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#666, Dark=#999}"
                               LineBreakMode="WordWrap"
                               MaxLines="2"/>
                        <Label Text="{Binding MonthCountText}"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light=#888, Dark=#888}"
                               LineBreakMode="WordWrap"
                               MaxLines="2"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ===== Мини-график 1ПМ ===== -->
            <Border Padding="14"
                    StrokeShape="RoundRectangle 14"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#2A2A2A}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}"
                    IsVisible="{Binding HasMiniChart}">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="2">
                    <Label Grid.Row="0"
                           Text="{Binding MiniChartTitle}"
                           FontSize="13"
                           FontAttributes="Bold"
                           LineBreakMode="TailTruncation"
                           MaxLines="1"/>
                    <Label Grid.Row="1"
                           Text="{Binding MiniChartSubtitle}"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#666, Dark=#999}"/>
                    <GraphicsView Grid.Row="2"
                                  Drawable="{Binding Mini1RmChart}"
                                  HeightRequest="100"
                                  Margin="0,6,0,0"/>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
