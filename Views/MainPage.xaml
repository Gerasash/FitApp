<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FitApp.ViewModels"
             x:Class="FitApp.Views.MainPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="{AppThemeBinding Light=#F2F4F7, Dark=#0F0F11}"
             Title="Главная">

    <ContentPage.Resources>

        <!-- Стиль карточки-контейнера — переиспользуем во всех секциях -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 16"/>
            <Setter Property="Stroke" Value="{AppThemeBinding Light=#E5E7EB, Dark=#2A2A2A}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark=#1A1A1A}"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <!-- Лейбл-рубрика над содержимым карточки -->
        <Style x:Key="CardLabel" TargetType="Label">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"/>
            <Setter Property="CharacterSpacing" Value="1"/>
        </Style>

    </ContentPage.Resources>

    <ScrollView>
        <Grid>

            <!-- ═══════════════════════════════════════════════════
                 ТЕЛЕФОН / планшет — вертикальная колонка
            ════════════════════════════════════════════════════════ -->
            <VerticalStackLayout Padding="16,16,16,32"
                                 Spacing="12"
                                 IsVisible="{OnIdiom Default=True, Desktop=False}">

                <!-- Hero: только при пустой БД -->
                <VerticalStackLayout Spacing="12"
                                     Padding="4,16,4,8"
                                     IsVisible="{Binding IsEmpty}">
                    <Label Text="🏋️ FitApp"
                           FontSize="34"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Ваш тренировочный дневник"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                           HorizontalOptions="Center"/>
                    <Label Text="Создайте первую тренировку — приложение начнёт собирать историю и подскажет рабочий вес."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,4,0,16"/>
                    <Button Text="➕  Начать тренировку"
                            FontSize="17"
                            FontAttributes="Bold"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="56"
                            Command="{Binding StartWorkoutCommand}"/>
                </VerticalStackLayout>

                <!-- Карточка планировщика -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        IsVisible="{Binding HasPlan}">
                    <VerticalStackLayout Padding="18" Spacing="6">
                        <Label Text="🎯  СЛЕДУЮЩАЯ ТРЕНИРОВКА"
                               Style="{StaticResource CardLabel}"
                               TextColor="White"
                               Opacity="0.8"/>
                        <Label Text="{Binding PlanExerciseName}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                        <HorizontalStackLayout Spacing="16" Margin="0,4,0,0">
                            <Label Text="{Binding PlanWeightText}"
                                   FontSize="30"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                            <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                <Label Text="{Binding PlanSetsRepsText}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="White"/>
                                <Label Text="{Binding PlanRpeText}"
                                       FontSize="13"
                                       TextColor="White"
                                       Opacity="0.8"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <Button Text="▶  Начать тренировку"
                                FontSize="15"
                                FontAttributes="Bold"
                                BackgroundColor="White"
                                TextColor="{StaticResource Primary}"
                                CornerRadius="12"
                                HeightRequest="48"
                                Margin="0,10,0,0"
                                Command="{Binding StartWorkoutCommand}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Подсказка планировщика -->
                <Border Style="{StaticResource Card}"
                        IsVisible="{Binding HasPlanHint}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="🎯  ПЛАНИРОВЩИК"
                               Style="{StaticResource CardLabel}"/>
                        <Label Text="Накопите ещё пару тренировок одного упражнения — и планировщик начнёт советовать рабочий вес."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                               LineBreakMode="WordWrap"/>
                        <Button Text="▶  Начать тренировку"
                                FontSize="14"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="44"
                                Margin="0,4,0,0"
                                Command="{Binding StartWorkoutCommand}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Сводки: Последняя тренировка | Активность -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      IsVisible="{Binding HasLastWorkout}">

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLastWorkoutCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="ПОСЛЕДНЯЯ" Style="{StaticResource CardLabel}"/>
                            <Label Text="{Binding LastWorkoutName}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>
                            <Label Text="{Binding LastWorkoutWhen}"
                                   FontSize="13"
                                   TextColor="{StaticResource Primary}"/>
                            <Label Text="{Binding LastWorkoutMeta}"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="АКТИВНОСТЬ" Style="{StaticResource CardLabel}"/>
                            <Label Text="{Binding WeekCountText}"
                                   FontSize="34"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"/>
                            <Label Text="{Binding WeekCountCaption}"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2"/>
                            <Label Text="{Binding MonthCountText}"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Мини-график -->
                <Border Style="{StaticResource Card}"
                        IsVisible="{Binding HasMiniChart}">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding MiniChartTitle}"
                               FontSize="14"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                        <Label Text="{Binding MiniChartSubtitle}"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                        <GraphicsView Drawable="{Binding Mini1RmChart}"
                                      HeightRequest="100"
                                      Margin="0,8,0,0"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>


            <!-- ═══════════════════════════════════════════════════
                 ПК — две колонки: план слева, сводки+график справа
            ════════════════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="20"
                  Padding="40,32,40,40"
                  VerticalOptions="Start"
                  IsVisible="{OnIdiom Default=False, Desktop=True}">

                <!-- ── Левая колонка ── -->
                <VerticalStackLayout Grid.Column="0" Spacing="16">

                    <!-- Hero при пустой БД -->
                    <VerticalStackLayout Spacing="16"
                                         Padding="0,8,0,0"
                                         IsVisible="{Binding IsEmpty}">
                        <Label Text="🏋️ FitApp"
                               FontSize="40"
                               FontAttributes="Bold"/>
                        <Label Text="Ваш тренировочный дневник"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                        <Label Text="Создайте первую тренировку — приложение начнёт собирать историю и подскажет рабочий вес."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                               LineBreakMode="WordWrap"/>
                        <Button Text="➕  Начать тренировку"
                                FontSize="16"
                                FontAttributes="Bold"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="56"
                                HorizontalOptions="Fill"
                                Command="{Binding StartWorkoutCommand}"/>
                    </VerticalStackLayout>

                    <!-- Карточка планировщика (большая, заполняет колонку) -->
                    <Border StrokeShape="RoundRectangle 18"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource Primary}"
                            IsVisible="{Binding HasPlan}">
                        <VerticalStackLayout Padding="24" Spacing="8">
                            <Label Text="🎯  СЛЕДУЮЩАЯ ТРЕНИРОВКА"
                                   Style="{StaticResource CardLabel}"
                                   TextColor="White"
                                   Opacity="0.8"/>
                            <Label Text="{Binding PlanExerciseName}"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>
                            <HorizontalStackLayout Spacing="20" Margin="0,8,0,0">
                                <Label Text="{Binding PlanWeightText}"
                                       FontSize="40"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalOptions="Center"/>
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding PlanSetsRepsText}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="White"/>
                                    <Label Text="{Binding PlanRpeText}"
                                           FontSize="14"
                                           TextColor="White"
                                           Opacity="0.8"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                            <Button Text="▶  Начать тренировку"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="White"
                                    TextColor="{StaticResource Primary}"
                                    CornerRadius="12"
                                    HeightRequest="52"
                                    Margin="0,16,0,0"
                                    Command="{Binding StartWorkoutCommand}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Подсказка планировщика -->
                    <Border Style="{StaticResource Card}"
                            IsVisible="{Binding HasPlanHint}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="🎯  ПЛАНИРОВЩИК"
                                   Style="{StaticResource CardLabel}"/>
                            <Label Text="Накопите ещё пару тренировок одного упражнения — и планировщик начнёт советовать рабочий вес."
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                                   LineBreakMode="WordWrap"/>
                            <Button Text="▶  Начать тренировку"
                                    FontSize="15"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    CornerRadius="12"
                                    HeightRequest="48"
                                    Margin="0,4,0,0"
                                    Command="{Binding StartWorkoutCommand}"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

                <!-- ── Правая колонка ── -->
                <VerticalStackLayout Grid.Column="1" Spacing="16"
                                     IsVisible="{Binding HasLastWorkout}">

                    <!-- Последняя тренировка -->
                    <Border Style="{StaticResource Card}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLastWorkoutCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="ПОСЛЕДНЯЯ ТРЕНИРОВКА"
                                   Style="{StaticResource CardLabel}"/>
                            <Label Text="{Binding LastWorkoutName}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>
                            <Label Text="{Binding LastWorkoutWhen}"
                                   FontSize="14"
                                   TextColor="{StaticResource Primary}"/>
                            <Label Text="{Binding LastWorkoutMeta}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Активность -->
                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="АКТИВНОСТЬ"
                                   Style="{StaticResource CardLabel}"/>
                            <Label Text="{Binding WeekCountText}"
                                   FontSize="40"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"/>
                            <Label Text="{Binding WeekCountCaption}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                            <Label Text="{Binding MonthCountText}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Мини-график -->
                    <Border Style="{StaticResource Card}"
                            IsVisible="{Binding HasMiniChart}">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding MiniChartTitle}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>
                            <Label Text="{Binding MiniChartSubtitle}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                            <GraphicsView Drawable="{Binding Mini1RmChart}"
                                          HeightRequest="120"
                                          Margin="0,8,0,0"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

            </Grid>

        </Grid>
    </ScrollView>
</ContentPage>
