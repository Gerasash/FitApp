<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitApp.Views.ProgressPage"
             xmlns:vm="clr-namespace:FitApp.ViewModels"
             x:DataType="vm:ProgressViewModel"
             Title="Прогресс">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Переключатель режимов -->
            <Border Padding="4" StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#ECEFF1, Dark=#2A2A2A}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                    <Button Grid.Column="0"
                            Text="Обзор"
                            Command="{Binding ShowOverviewCommand}"
                            CornerRadius="10"
                            FontAttributes="Bold"
                            HeightRequest="40">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsOverviewMode}" Value="True">
                                <Setter Property="BackgroundColor" Value="#673AB7"/>
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsOverviewMode}" Value="False">
                                <Setter Property="BackgroundColor" Value="Transparent"/>
                                <Setter Property="TextColor"
                                        Value="{AppThemeBinding Light=#37474F, Dark=#CFD8DC}"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Grid.Column="1"
                            Text="По упражнению"
                            Command="{Binding ShowExerciseCommand}"
                            CornerRadius="10"
                            FontAttributes="Bold"
                            HeightRequest="40">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsExerciseMode}" Value="True">
                                <Setter Property="BackgroundColor" Value="#673AB7"/>
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsExerciseMode}" Value="False">
                                <Setter Property="BackgroundColor" Value="Transparent"/>
                                <Setter Property="TextColor"
                                        Value="{AppThemeBinding Light=#37474F, Dark=#CFD8DC}"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </Border>

            <!-- ============== ОБЗОР ============== -->
            <VerticalStackLayout Spacing="16" IsVisible="{Binding IsOverviewMode}">

                <!-- 4 KPI карточки 2×2 -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                      ColumnSpacing="10" RowSpacing="10">

                    <Border Grid.Row="0" Grid.Column="0" Padding="14" StrokeThickness="0"
                            BackgroundColor="#E3F2FD">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="💪 Тренировок в месяце"
                                   FontSize="12" TextColor="#1565C0"/>
                            <Label Text="{Binding WorkoutsThisMonth}"
                                   FontSize="26" FontAttributes="Bold" TextColor="#0D47A1"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Padding="14" StrokeThickness="0"
                            BackgroundColor="#FFF3E0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="🏋️ Тоннаж в месяце"
                                   FontSize="12" TextColor="#E65100"/>
                            <Label Text="{Binding TonnageThisMonth}"
                                   FontSize="22" FontAttributes="Bold" TextColor="#BF360C"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Padding="14" StrokeThickness="0"
                            BackgroundColor="#E8F5E9">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="🔥 Стрик подряд"
                                   FontSize="12" TextColor="#2E7D32"/>
                            <Label Text="{Binding StreakDays, StringFormat='{0} дн.'}"
                                   FontSize="22" FontAttributes="Bold" TextColor="#1B5E20"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Padding="14" StrokeThickness="0"
                            BackgroundColor="#FCE4EC">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="📊 Средн. RPE недели"
                                   FontSize="12" TextColor="#AD1457"/>
                            <Label Text="{Binding AvgRpeWeek}"
                                   FontSize="22" FontAttributes="Bold" TextColor="#880E4F"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Сравнение недель -->
                <Border Padding="14" StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#F3E5F5, Dark=#3A2A4A}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Эта неделя"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#6A1B9A, Dark=#CE93D8}"/>
                        <Label Text="{Binding WeekComparison}"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#4A148C, Dark=#E1BEE7}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- PR-лента -->
                <Border Padding="14" StrokeThickness="0"
                        IsVisible="{Binding HasPrs}"
                        BackgroundColor="{AppThemeBinding Light=#FFFDE7, Dark=#3A341A}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🏆 Свежие рекорды"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#F57F17, Dark=#FFE082}"/>
                        <VerticalStackLayout Spacing="6"
                                             BindableLayout.ItemsSource="{Binding RecentPrs}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:PrEntry">
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                        <VerticalStackLayout Grid.Column="0">
                                            <Label Text="{Binding Title}"
                                                   FontSize="14" FontAttributes="Bold"/>
                                            <Label Text="{Binding Subtitle}"
                                                   FontSize="12" TextColor="Gray"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="🏆"
                                               FontSize="20" VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Heatmap календарь -->
                <Border Padding="14" StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Активность за 12 недель"
                               FontSize="16" FontAttributes="Bold"/>
                        <Label Text="{Binding HeatmapHint}"
                               FontSize="11" TextColor="Gray"/>

                        <!-- Кастомный календарь: дни недели слева, месяцы сверху, число дня в цветной ячейке -->
                        <GraphicsView x:Name="ActivityCalendar"
                                      HeightRequest="170"
                                      HorizontalOptions="Fill">
                            <GraphicsView.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCalendarTapped"/>
                            </GraphicsView.GestureRecognizers>
                        </GraphicsView>

                        <!-- Легенда -->
                        <HorizontalStackLayout Spacing="6" HorizontalOptions="End">
                            <Label Text="меньше" FontSize="10" TextColor="Gray"
                                   VerticalOptions="Center"/>
                            <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="2"
                                     Color="{AppThemeBinding Light=#EBEDF0, Dark=#2A2A2A}"/>
                            <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="2"
                                     Color="#C8E6C9"/>
                            <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="2"
                                     Color="#81C784"/>
                            <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="2"
                                     Color="#43A047"/>
                            <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="2"
                                     Color="#1B5E20"/>
                            <Label Text="больше" FontSize="10" TextColor="Gray"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ============== ПО УПРАЖНЕНИЮ ============== -->
            <VerticalStackLayout Spacing="16" IsVisible="{Binding IsExerciseMode}">

                <!-- Выбор упражнения -->
                <Border Padding="14" StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D30}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Упражнение" FontSize="13" TextColor="Gray"/>
                        <Picker ItemsSource="{Binding Exercises}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedExercise, Mode=TwoWay}"
                                FontSize="16"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Карточки статистики -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                    <Border Grid.Column="0" Padding="12" StrokeThickness="0" BackgroundColor="#E8F5E9">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="🏆 Рекорд" FontSize="11" TextColor="#2E7D32"/>
                            <Label Text="{Binding MaxWeight, StringFormat='{0} кг'}"
                                   FontSize="20" FontAttributes="Bold" TextColor="#1B5E20"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Padding="12" StrokeThickness="0" BackgroundColor="#E3F2FD">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="💪 Тренировок" FontSize="11" TextColor="#1565C0"/>
                            <Label Text="{Binding TotalWorkouts}"
                                   FontSize="20" FontAttributes="Bold" TextColor="#0D47A1"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Padding="12" StrokeThickness="0" BackgroundColor="#FFF3E0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="🔥 Ср. RPE" FontSize="11" TextColor="#E65100"/>
                            <Label Text="{Binding AvgRpe}"
                                   FontSize="20" FontAttributes="Bold" TextColor="#BF360C"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Прогноз -->
                <Border Padding="16" StrokeThickness="0" BackgroundColor="#EDE7F6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0" Text="🤖" FontSize="36" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                                <Label Text="Прогноз ИИ — какой 1ПМ атлет сможет совершить"
                                       FontSize="13" TextColor="#6A1B9A"/>
                                <Label Text="{Binding ForecastLabel}"
                                       FontSize="18" FontAttributes="Bold" TextColor="#4A148C"/>
                                <Label Text="{Binding TrendLabel}"
                                       FontSize="14" TextColor="#7B1FA2"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Слайдер горизонта прогноза -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10"
                              VerticalOptions="Center">
                            <Label Grid.Column="0" Text="Горизонт:" FontSize="13"
                                   TextColor="#6A1B9A" VerticalOptions="Center"/>
                            <Slider Grid.Column="1"
                                    Minimum="1" Maximum="6"
                                    Value="{Binding ForecastMonths, Mode=TwoWay}"
                                    MinimumTrackColor="#673AB7"
                                    ThumbColor="#673AB7"
                                    VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="{Binding ForecastMonthsLabel}"
                                   FontSize="14" FontAttributes="Bold" TextColor="#4A148C"
                                   WidthRequest="56" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- График: рабочий вес (фиолетовая) + расчётный 1ПМ (оранжевый пунктир) + прогноз 1ПМ (зелёный пунктир) -->
                <Border Padding="14" StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="График веса" FontSize="16" FontAttributes="Bold"/>
                        <Label Text="Фиолетовая — рабочий вес. Оранжевый пунктир — расчётный 1ПМ (Эпли). Зелёный пунктир — прогноз 1ПМ, который атлет сможет совершить."
                               FontSize="11" TextColor="Gray"/>
                        <ContentView x:Name="ChartHost" HeightRequest="240"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
