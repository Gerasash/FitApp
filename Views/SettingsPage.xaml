<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitApp.Views.SettingsPage"
             Title="Настройки">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- ==== Профиль ==== -->
            <Label Text="Профиль" Style="{StaticResource SectionTitle}"/>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">

                    <!-- Имя -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Имя" FontSize="15"/>
                        <Label Text="Используется для приветствия" Style="{StaticResource Caption}"/>
                        <Entry x:Name="DisplayNameEntry"
                               Placeholder="Например, Гера"
                               Unfocused="OnProfileChanged"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderSubtleLight}, Dark={StaticResource BorderSubtleDark}}"/>

                    <!-- Вес -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Вес тела"
                               FontSize="15"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Кг. Используется моделью прогноза"
                               Style="{StaticResource Caption}"/>
                        <Entry x:Name="BodyweightEntry"
                               Grid.Row="0" Grid.Column="1"
                               Grid.RowSpan="2"
                               WidthRequest="90"
                               Keyboard="Numeric"
                               Placeholder="0"
                               HorizontalTextAlignment="End"
                               Unfocused="OnProfileChanged"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderSubtleLight}, Dark={StaticResource BorderSubtleDark}}"/>

                    <!-- Возраст -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Возраст"
                               FontSize="15"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Полных лет"
                               Style="{StaticResource Caption}"/>
                        <Entry x:Name="AgeEntry"
                               Grid.Row="0" Grid.Column="1"
                               Grid.RowSpan="2"
                               WidthRequest="90"
                               Keyboard="Numeric"
                               Placeholder="0"
                               HorizontalTextAlignment="End"
                               Unfocused="OnProfileChanged"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderSubtleLight}, Dark={StaticResource BorderSubtleDark}}"/>

                    <!-- Пол -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Пол"
                               FontSize="15"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Фича для модели прогноза"
                               Style="{StaticResource Caption}"/>
                        <Picker x:Name="SexPicker"
                                Grid.Row="0" Grid.Column="1"
                                Grid.RowSpan="2"
                                WidthRequest="140"
                                SelectedIndexChanged="OnProfileChanged">
                            <Picker.Items>
                                <x:String>Не указан</x:String>
                                <x:String>Мужской</x:String>
                                <x:String>Женский</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderSubtleLight}, Dark={StaticResource BorderSubtleDark}}"/>

                    <!-- Начало занятий -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Начало занятий"
                               FontSize="15"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Когда начал тренироваться"
                               Style="{StaticResource Caption}"/>
                        <DatePicker x:Name="ExperienceStartDatePicker"
                                    Grid.Row="0" Grid.Column="1"
                                    Grid.RowSpan="2"
                                    Format="dd.MM.yyyy"
                                    DateSelected="OnProfileChanged"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderSubtleLight}, Dark={StaticResource BorderSubtleDark}}"/>

                    <!-- Целевой RPE -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Целевой RPE"
                               FontSize="15"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="К нему подгоняет нагрузку планировщик"
                               Style="{StaticResource Caption}"/>
                        <Picker x:Name="TargetRpePicker"
                                Grid.Row="0" Grid.Column="1"
                                Grid.RowSpan="2"
                                WidthRequest="100"
                                SelectedIndexChanged="OnProfileChanged">
                            <Picker.Items>
                                <x:String>6.0</x:String>
                                <x:String>6.5</x:String>
                                <x:String>7.0</x:String>
                                <x:String>7.5</x:String>
                                <x:String>8.0</x:String>
                                <x:String>8.5</x:String>
                                <x:String>9.0</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ==== Внешний вид ==== -->
            <Label Text="Внешний вид" Style="{StaticResource SectionTitle}"/>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">

                    <!-- Тема -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Тема оформления"
                               FontSize="15"
                               VerticalOptions="Center"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Светлая / Тёмная / Системная"
                               Style="{StaticResource Caption}"/>
                        <Picker x:Name="ThemePicker"
                                Grid.Row="0" Grid.Column="1"
                                Grid.RowSpan="2"
                                WidthRequest="140"
                                SelectedIndexChanged="OnThemeChanged">
                            <Picker.Items>
                                <x:String>Светлая</x:String>
                                <x:String>Тёмная</x:String>
                                <x:String>Системная</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ==== Тренировки ==== -->
            <Label Text="Тренировки" Style="{StaticResource SectionTitle}" Margin="0,8,0,0"/>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">

                    <!-- Единицы измерения -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Единицы измерения"
                               FontSize="15"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Килограммы или фунты"
                               Style="{StaticResource Caption}"/>
                        <Picker x:Name="UnitsPicker"
                                Grid.Row="0" Grid.Column="1"
                                Grid.RowSpan="2"
                                WidthRequest="110"
                                SelectedIndexChanged="OnUnitsChanged">
                            <Picker.Items>
                                <x:String>кг</x:String>
                                <x:String>lb</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderSubtleLight}, Dark={StaticResource BorderSubtleDark}}"/>

                    <!-- Таймер отдыха по умолчанию -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Таймер отдыха"
                               FontSize="15"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Длительность по умолчанию"
                               Style="{StaticResource Caption}"/>
                        <Picker x:Name="RestTimerPicker"
                                Grid.Row="0" Grid.Column="1"
                                Grid.RowSpan="2"
                                WidthRequest="130"
                                SelectedIndexChanged="OnRestTimerChanged">
                            <Picker.Items>
                                <x:String>60 сек</x:String>
                                <x:String>90 сек</x:String>
                                <x:String>120 сек</x:String>
                                <x:String>180 сек</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource BorderSubtleLight}, Dark={StaticResource BorderSubtleDark}}"/>

                    <!-- Звук -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Звук таймера" FontSize="15"/>
                            <Label Text="Сигнал по завершении отдыха" Style="{StaticResource Caption}"/>
                        </VerticalStackLayout>
                        <Switch x:Name="SoundSwitch"
                                Grid.Column="1"
                                VerticalOptions="Center"
                                Toggled="OnSoundToggled"/>
                    </Grid>

                    <!-- Вибрация -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Вибрация" FontSize="15"/>
                            <Label Text="Вибрация по завершении отдыха" Style="{StaticResource Caption}"/>
                        </VerticalStackLayout>
                        <Switch x:Name="VibrationSwitch"
                                Grid.Column="1"
                                VerticalOptions="Center"
                                Toggled="OnVibrationToggled"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ==== Данные ==== -->
            <Label Text="Данные" Style="{StaticResource SectionTitle}" Margin="0,8,0,0"/>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Button Text="📤 Экспорт в CSV"
                            Style="{StaticResource SecondaryAction}"
                            Clicked="OnExportCsv"/>
                </VerticalStackLayout>
            </Border>

            <!-- ==== О приложении ==== -->
            <Label Text="О приложении" Style="{StaticResource SectionTitle}" Margin="0,8,0,0"/>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="FitApp" FontSize="16" FontAttributes="Bold"/>
                    <Label Text="Версия 1.0" Style="{StaticResource Caption}"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
