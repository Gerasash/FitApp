<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FitApp.Views.TemplateEditorPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FitApp.ViewModels"
             x:Name="PageRoot"
             x:DataType="vm:TemplateEditorViewModel"
             Title="Редактор шаблона">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- Метаданные шаблона -->
                <Label Text="Название" FontSize="12" TextColor="Gray"/>
                <Entry Text="{Binding Name, Mode=TwoWay}" Placeholder="Push Day"/>

                <Label Text="Папка" FontSize="12" TextColor="Gray"/>
                <Entry Text="{Binding Folder, Mode=TwoWay}" Placeholder="PPL, Мои, …"/>

                <Label Text="Описание" FontSize="12" TextColor="Gray"/>
                <Editor Text="{Binding Description, Mode=TwoWay}"
                        Placeholder="Короткое описание шаблона"
                        AutoSize="TextChanges"
                        HeightRequest="60"/>

                <!-- Упражнения -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                    <Label Grid.Column="0" Text="Упражнения" FontSize="16" FontAttributes="Bold"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1"
                            Text="+ Добавить"
                            FontSize="13"
                            Padding="12,6"
                            Clicked="OnAddExerciseClicked"
                            BackgroundColor="#3B82F6"
                            TextColor="White"/>
                </Grid>

                <CollectionView ItemsSource="{Binding Rows}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="Пока нет упражнений. Нажми «+ Добавить»."
                               HorizontalOptions="Center" TextColor="Gray" Margin="20"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TemplateExerciseRow">
                            <Border Margin="0,4"
                                    Padding="12"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1C1C1E}">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">

                                    <!-- Название упражнения -->
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding ExerciseName}"
                                           FontSize="15" FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

                                    <!-- Кнопки управления -->
                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4">
                                        <Button Text="↑" FontSize="13" Padding="8,4"
                                                BackgroundColor="Transparent"
                                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.MoveUpCommand}"
                                                CommandParameter="{Binding .}"/>
                                        <Button Text="↓" FontSize="13" Padding="8,4"
                                                BackgroundColor="Transparent"
                                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.MoveDownCommand}"
                                                CommandParameter="{Binding .}"/>
                                        <Button Text="🗑" FontSize="13" Padding="8,4"
                                                BackgroundColor="Transparent"
                                                TextColor="#EF4444"
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.DeleteRowCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </HorizontalStackLayout>

                                    <!-- Поля плана -->
                                    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                          ColumnDefinitions="Auto,60,Auto,60,Auto,60,Auto"
                                          ColumnSpacing="6" VerticalOptions="Center">
                                        <Label Grid.Column="0" Text="Подходов:" VerticalOptions="Center" FontSize="13"/>
                                        <Entry Grid.Column="1" Text="{Binding TargetSets, Mode=TwoWay}"
                                               Keyboard="Numeric" FontSize="13"
                                               HorizontalTextAlignment="Center"/>

                                        <Label Grid.Column="2" Text="Повторы:" VerticalOptions="Center" FontSize="13"/>
                                        <Entry Grid.Column="3" Text="{Binding RepsMin, Mode=TwoWay}"
                                               Keyboard="Numeric" FontSize="13"
                                               Placeholder="мин"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Grid.Column="4" Text="–" VerticalOptions="Center" FontSize="13"/>
                                        <Entry Grid.Column="5" Text="{Binding RepsMax, Mode=TwoWay}"
                                               Keyboard="Numeric" FontSize="13"
                                               Placeholder="макс"
                                               HorizontalTextAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Низ: Сохранить -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="16,8" ColumnSpacing="12">
            <Button Grid.Column="0"
                    Text="Назад"
                    Clicked="OnBackClicked"
                    BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3C}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
            <Button Grid.Column="1"
                    Text="Сохранить"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#10B981"
                    TextColor="White"/>
        </Grid>
    </Grid>
</ContentPage>
