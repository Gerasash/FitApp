<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitApp.Views.WorkoutListPage"
             xmlns:local="clr-namespace:FitApp.ViewModels"
             xmlns:models="clr-namespace:FitApp.Models"
             Title="Тренировки">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Заголовок -->
            <Label Text="Мои тренировки"
                   FontSize="24"
                   FontAttributes="Bold"/>

            <Label Text="Создание, фильтрация и список тренировок."
                   FontSize="13"
                   TextColor="Gray"
                   Margin="0,-8,0,0"/>

            <!-- Панель фильтров -->
            <Border Padding="14"
                    BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1E3A5F}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Фильтры"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0D47A1, Dark=#E3F2FD}"/>

                    <!-- Фильтр по дате -->
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <DatePicker Grid.Column="0"
                                    Date="{Binding FilterDate, Mode=TwoWay}"
                                    Format="d"
                                    MinimumDate="1/1/2020"
                                    MaximumDate="1/1/2030"/>

                        <Button Grid.Column="1"
                                Text="🔍"
                                Command="{Binding FilterByDateCommand}"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                CornerRadius="10"
                                WidthRequest="52"
                                HeightRequest="44"/>

                        <Button Grid.Column="2"
                                Text="Все"
                                Command="{Binding ShowAllWorkoutsCommand}"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                CornerRadius="10"
                                WidthRequest="64"
                                HeightRequest="44"/>
                    </Grid>

                    <!-- Фильтр по группе мышц -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Picker Grid.Column="0"
                                Title="Группа мышц"
                                ItemsSource="{Binding AllMuscleGroups}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedFilterMuscleGroup, Mode=TwoWay}" />

                        <Button Grid.Column="1"
                                Text="Фильтр"
                                Command="{Binding FilterByMuscleGroupCommand}"
                                BackgroundColor="#673AB7"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="44"/>
                    </Grid>

                    <Button Text="Сбросить фильтры"
                            Command="{Binding ShowAllWorkoutsCommand}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#263238}"
                            TextColor="{AppThemeBinding Light=#1E88E5, Dark=#BBDEFB}"
                            CornerRadius="10"
                            HeightRequest="44"/>
                </VerticalStackLayout>
            </Border>

            <!-- Карточка создания тренировки -->
            <Border Padding="14"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D30}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <Label Text="➕ Новая тренировка"
                           FontSize="18"
                           FontAttributes="Bold"/>

                    <Entry Placeholder="Название тренировки"
                           Text="{Binding WorkoutName, Mode=TwoWay}"
                           ClearButtonVisibility="WhileEditing"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Дата" FontSize="12" TextColor="Gray"/>
                            <DatePicker Date="{Binding SelectedDate, Mode=TwoWay}" Format="d"
                                        MinimumDate="1/1/2010"
                                        MaximumDate="1/1/2030"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Время" FontSize="12" TextColor="Gray"/>
                            <TimePicker Time="{Binding SelectedTime, Mode=TwoWay}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Button Text="Добавить тренировку"
                            Command="{Binding AddWorkoutCommand}"
                            BackgroundColor="#FF9800"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="50"/>
                </VerticalStackLayout>
            </Border>

            <!-- Список тренировок -->
            <Label Text="Список"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,6,0,0"/>

            <CollectionView ItemsSource="{Binding FilteredWorkouts}"
                            SelectionMode="None">

                <CollectionView.EmptyView>
                    <Border Padding="24"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="💪" FontSize="44" HorizontalOptions="Center"/>
                            <Label Text="Тренировок нет"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                            <Label Text="Добавь свою первую тренировку через форму выше или сбрось фильтры."
                                   FontSize="13"
                                   TextColor="Gray"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Workout">
                        <SwipeView Threshold="80">
                            <!-- свайп для удаления -->
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItem Text="Удалить"
                                               BackgroundColor="#E53935"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type local:WorkoutViewModel}}, Path=DeleteWorkoutCommand}"
                                               CommandParameter="{Binding .}"/>
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <!-- карточка тренировки -->
                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnWorkoutTapped"
                                                          CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="*,Auto,Auto"
      RowDefinitions="Auto,Auto"
      ColumnSpacing="10">

                                    <Label Grid.Row="0" Grid.Column="0"
           Text="{Binding Name}"
           FontSize="16"
           FontAttributes="Bold"/>

                                    <Label Grid.Row="1" Grid.Column="0"
           Text="{Binding StartTime, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
           FontSize="13"
           TextColor="Gray"/>

                                    <!-- 🗑 кнопка удаления -->
                                    <Button Grid.RowSpan="2" Grid.Column="1"
            Text="🗑"
            FontSize="16"
            WidthRequest="44"
            HeightRequest="44"
            CornerRadius="12"
            BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#3A1E1E}"
            TextColor="#E53935"
            Command="{Binding Source={RelativeSource AncestorType={x:Type local:WorkoutViewModel}}, Path=DeleteWorkoutCommand}"
            CommandParameter="{Binding .}"/>

                                    <!-- стрелка перехода -->
                                    <Label Grid.RowSpan="2" Grid.Column="2"
           Text="›"
           FontSize="26"
           TextColor="Gray"
           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
