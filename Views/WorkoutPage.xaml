<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitApp.Views.WorkoutPage"
             xmlns:local="clr-namespace:FitApp.ViewModels"
             xmlns:models="clr-namespace:FitApp.Models"
             Title="{Binding WorkoutName}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- Шапка тренировки -->
                <Border Padding="14"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D30}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Группы мышц"
                               FontAttributes="Bold"
                               FontSize="16"/>

                        <CollectionView ItemsSource="{Binding AllMuscleGroups}"
                                        SelectionMode="Multiple"
                                        SelectedItems="{Binding SelectedMuscleGroups}"
                                        ItemsLayout="HorizontalList"
                                        HeightRequest="54">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,8"
                                            Margin="0,0,10,0"
                                            StrokeThickness="1"
                                            Stroke="{AppThemeBinding Light=#BDBDBD, Dark=#5A5A5A}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="999"/>
                                        </Border.StrokeShape>

                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup Name="CommonStates">
                                                <VisualState Name="Normal">
                                                    <VisualState.Setters>
                                                        <Setter Property="BackgroundColor"
                                                                Value="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                                <VisualState Name="Selected">
                                                    <VisualState.Setters>
                                                        <Setter Property="BackgroundColor"
                                                                Value="{AppThemeBinding Light=#C8E6C9, Dark=#1B5E20}" />
                                                        <Setter Property="Stroke"
                                                                Value="{AppThemeBinding Light=#2E7D32, Dark=#66BB6A}" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>

                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="Тап по тегам — выбрать/снять."
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Верхняя панель действий -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Label Grid.Column="0"
                           Text="Упражнения"
                           FontSize="18"
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>

                    <Button Grid.Column="1"
                            Text="➕ Упражнение"
                            HeightRequest="44"
                            Padding="14,0"
                            CornerRadius="12"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            Clicked="ToModalPage"/>
                </Grid>

                <!-- Список упражнений -->
                <CollectionView ItemsSource="{Binding WorkoutExercises}"
                                SelectionMode="None">

                    <CollectionView.EmptyView>
                        <Border Padding="18"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D30}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Label Text="Пока нет упражнений"
                                       FontAttributes="Bold"
                                       FontSize="16"/>
                                <Label Text="Нажми “➕ Упражнение”, чтобы добавить первое."
                                       TextColor="Gray"
                                       FontSize="13"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:WorkoutExercise">
                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>

                                <VerticalStackLayout Spacing="10">

                                    <!-- Заголовок упражнения -->
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                        <Border Grid.Column="0"
                                                WidthRequest="34"
                                                HeightRequest="34"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light=#F3E5F5, Dark=#3A2A4A}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Label Text="{Binding OrderIndex}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#6A1B9A, Dark=#E1BEE7}"/>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding ExerciseName}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"/>
                                            <Label Text="Подходы:"
                                                   FontSize="12"
                                                   TextColor="Gray"/>
                                        </VerticalStackLayout>

                                        <!-- ➕ Подход -->
                                        <Button Grid.Column="2"
                                                Text="➕ Подход"
                                                FontSize="13"
                                                HeightRequest="36"
                                                Padding="12,0"
                                                CornerRadius="12"
                                                BackgroundColor="#FF9800"
                                                TextColor="White"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type local:WorkoutViewModel}}, Path=AddSetCommand}"
                                                CommandParameter="{Binding .}"/>

                                        <!-- 🗑 Удалить упражнение -->
                                        <Button Grid.Column="3"
                                                Text="🗑"
                                                FontSize="16"
                                                HeightRequest="36"
                                                WidthRequest="44"
                                                CornerRadius="12"
                                                BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#3A1E1E}"
                                                TextColor="#E53935"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type local:WorkoutViewModel}}, Path=DeleteWorkoutExerciseCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>

                                    <!-- ИИ советует -->
                                    <Border IsVisible="{Binding HasAiInsight}"
                                            Padding="10,8"
                                            StrokeThickness="0"
                                            BackgroundColor="#E8F5E9">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding AiInsight}"
                                               FontSize="13"
                                               TextColor="#2E7D32"/>
                                    </Border>

                                    <!-- Подходы (свайп удалить, тап редактировать) -->
                                    <CollectionView ItemsSource="{Binding Sets}" SelectionMode="None">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:ExerciseSet">
                                                <SwipeView Threshold="80">
                                                    <SwipeView.RightItems>
                                                        <SwipeItems Mode="Reveal">
                                                            <SwipeItem Text="Удалить"
                                                                       BackgroundColor="#E53935"
                                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type local:WorkoutViewModel}}, Path=DeleteSetCommand}"
                                                                       CommandParameter="{Binding .}"/>
                                                        </SwipeItems>
                                                    </SwipeView.RightItems>

                                                    <Border Padding="12"
                                                            Margin="0,0,0,8"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{AppThemeBinding Light=#F7F7F7, Dark=#2A2A2A}">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="12"/>
                                                        </Border.StrokeShape>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type local:WorkoutViewModel}}, Path=EditSetCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                        </Border.GestureRecognizers>

                                                        <Grid ColumnDefinitions="Auto,*,*,Auto" ColumnSpacing="10">
                                                            <!-- Тапабельный бейдж типа подхода: 1/2/3 / W / F / D -->
                                                            <Border Grid.Column="0"
                                                                    StrokeThickness="1"
                                                                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"
                                                                    WidthRequest="34"
                                                                    HeightRequest="34"
                                                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                                                                    VerticalOptions="Center">
                                                                <Border.StrokeShape>
                                                                    <RoundRectangle CornerRadius="8"/>
                                                                </Border.StrokeShape>
                                                                <Border.GestureRecognizers>
                                                                    <TapGestureRecognizer
                                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:WorkoutViewModel}}, Path=ChangeSetTypeCommand}"
                                                                        CommandParameter="{Binding .}"/>
                                                                </Border.GestureRecognizers>
                                                                <Label Text="{Binding DisplayBadge}"
                                                                       TextColor="{Binding BadgeColor}"
                                                                       FontAttributes="Bold"
                                                                       FontSize="15"
                                                                       HorizontalOptions="Center"
                                                                       VerticalOptions="Center"/>
                                                            </Border>

                                                            <Label Grid.Column="1"
                                                                   Text="{Binding Weight, StringFormat='{0:F1} кг'}"
                                                                   VerticalOptions="Center"/>

                                                            <Label Grid.Column="2"
                                                                   Text="{Binding Reps, StringFormat='{0} повт'}"
                                                                   VerticalOptions="Center"/>

                                                            <Label Grid.Column="3"
                                                                   Text="✎"
                                                                   FontSize="14"
                                                                   TextColor="Gray"
                                                                   VerticalOptions="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </SwipeView>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,8">
                    <Button Grid.Column="0"
                            Text="💾 Сохранить"
                            Command="{Binding UpdateWorkoutCommand}"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="52"/>

                    <Button Grid.Column="1"
                            Text="Назад"
                            Clicked="OnBackButtonClicked"
                            BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#2D2D30}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            CornerRadius="14"
                            HeightRequest="52"/>
                </Grid>

                <Button Text="📋 Сохранить как шаблон"
                        Clicked="OnSaveAsTemplateClicked"
                        BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3C}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        CornerRadius="14"
                        HeightRequest="46"
                        Margin="0,0,0,20"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ====== Backdrop ====== -->
        <BoxView x:Name="Backdrop"
                 Color="Black"
                 Opacity="0"
                 InputTransparent="True"
                 IsVisible="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelSheetCommand}"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- ====== Bottom Sheet ====== -->
        <Border x:Name="SetSheet"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                Padding="20,16,20,24"
                TranslationY="800"
                IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20,20,0,0"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="16">

                <!-- Хваталка -->
                <BoxView WidthRequest="40" HeightRequest="4"
                         CornerRadius="2"
                         Color="{AppThemeBinding Light=#D0D0D0, Dark=#4A4A4A}"
                         HorizontalOptions="Center"/>

                <Label Text="{Binding SheetTitle}"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <!-- Вес -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Вес (кг)" FontSize="13" TextColor="Gray"/>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="−2.5"
                                FontSize="14"
                                HeightRequest="48"
                                WidthRequest="64"
                                CornerRadius="12"
                                BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#2D2D30}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                Command="{Binding AdjustWeightCommand}"
                                CommandParameter="-2.5"/>

                        <Entry Grid.Column="1"
                               Text="{Binding SheetWeight, Mode=TwoWay}"
                               Keyboard="Numeric"
                               HorizontalTextAlignment="Center"
                               FontSize="20"
                               FontAttributes="Bold"
                               HeightRequest="48"/>

                        <Button Grid.Column="2"
                                Text="+2.5"
                                FontSize="14"
                                HeightRequest="48"
                                WidthRequest="64"
                                CornerRadius="12"
                                BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#2D2D30}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                Command="{Binding AdjustWeightCommand}"
                                CommandParameter="2.5"/>
                    </Grid>
                </VerticalStackLayout>

                <!-- Повторы -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Повторы" FontSize="13" TextColor="Gray"/>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="−1"
                                FontSize="14"
                                HeightRequest="48"
                                WidthRequest="64"
                                CornerRadius="12"
                                BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#2D2D30}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                Command="{Binding AdjustRepsCommand}"
                                CommandParameter="-1"/>

                        <Entry Grid.Column="1"
                               Text="{Binding SheetReps, Mode=TwoWay}"
                               Keyboard="Numeric"
                               HorizontalTextAlignment="Center"
                               FontSize="20"
                               FontAttributes="Bold"
                               HeightRequest="48"/>

                        <Button Grid.Column="2"
                                Text="+1"
                                FontSize="14"
                                HeightRequest="48"
                                WidthRequest="64"
                                CornerRadius="12"
                                BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#2D2D30}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                Command="{Binding AdjustRepsCommand}"
                                CommandParameter="1"/>
                    </Grid>
                </VerticalStackLayout>

                <!-- RPE: большая цифра + описание + чипы как в Hevy -->
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="{Binding SheetRpe, StringFormat='{0:0.#}'}"
                           FontSize="46" FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding SheetRpeTitle}"
                           FontSize="15" FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding SheetRpeHint}"
                           FontSize="12" TextColor="Gray"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Горизонтальная шкала RPE -->
                <Border Padding="6" StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#ECEFF1, Dark=#2A2A2A}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22"/>
                    </Border.StrokeShape>
                    <CollectionView ItemsSource="{Binding RpeOptions}"
                                    SelectionMode="None"
                                    HeightRequest="36">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="local:RpeOption">
                                <Border StrokeThickness="0"
                                        WidthRequest="36"
                                        HeightRequest="36"
                                        BackgroundColor="Transparent">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18"/>
                                    </Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#2196F3"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type local:WorkoutViewModel}}, Path=SelectRpeCommand}"
                                            CommandParameter="{Binding Value}"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding Label}"
                                           FontSize="13"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="TextColor" Value="White"/>
                                                <Setter Property="FontAttributes" Value="Bold"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                                <Setter Property="TextColor"
                                                        Value="{AppThemeBinding Light=#37474F, Dark=#CFD8DC}"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <!-- Кнопки -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                    <Button Grid.Column="0"
                            Text="Отмена"
                            HeightRequest="50"
                            CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#2D2D30}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            Command="{Binding CancelSheetCommand}"/>

                    <Button Grid.Column="1"
                            Text="Сохранить"
                            HeightRequest="50"
                            CornerRadius="14"
                            BackgroundColor="#FF9800"
                            TextColor="White"
                            Command="{Binding SaveSheetCommand}"/>
                </Grid>

            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
